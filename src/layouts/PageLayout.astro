---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  jsonLdType?: 'LocalBusiness' | 'Service' | 'BlogPosting' | 'WebSite';
  jsonLdData?: Record<string, unknown>;
}

const { title, description, image, type, publishedDate, jsonLdType = 'WebSite', jsonLdData } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type={type} publishedDate={publishedDate}>
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
  <JsonLd type={jsonLdType} data={jsonLdData} />
</BaseLayout>
