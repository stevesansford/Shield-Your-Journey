---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ServiceCard from '../components/services/ServiceCard.astro';
import Button from '../components/ui/Button.astro';
import { services } from '../data/services';
import { siteInfo } from '../data/navigation';
---

<PageLayout
  title="Services"
  description="Explore Shield Your Journey's legal, identity, and cyber protection services designed for RV families traveling across the country."
  jsonLdType="Service"
  jsonLdData={{
    name: 'RV Family Protection Services',
    description: 'Legal, identity, and cyber protection for traveling families.',
    areaServed: 'US',
  }}
>
  <!-- Hero Banner -->
  <section class="bg-teal text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">Our Services</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">
        Comprehensive protection solutions tailored for the RV lifestyle.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeading
        title="What We Offer"
        subtitle="Three curated protection partnerships designed to cover every aspect of your family's safety on the road."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-dark mb-4">Not Sure Which Plan Is Right for You?</h2>
      <p class="text-gray-600 mb-6">
        Schedule a free consultation and we'll help you find the perfect protection package for your RV lifestyle.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <Button href="/contact/" variant="primary" size="lg">
          Schedule a Consultation
        </Button>
        <a href={siteInfo.phoneTel} class="text-teal hover:text-orange font-semibold">
          <i class="fa-solid fa-phone mr-2"></i>{siteInfo.phone}
        </a>
      </div>
    </div>
  </section>
</PageLayout>
