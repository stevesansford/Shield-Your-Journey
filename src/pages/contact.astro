---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { siteInfo } from '../data/navigation';
---

<PageLayout
  title="Contact"
  description="Get in touch with Shield Your Journey. Schedule a free consultation for legal, identity, and cyber protection for your RV family."
  jsonLdType="LocalBusiness"
>
  <!-- Hero Banner -->
  <section class="bg-teal text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
        Let's Protect Your RV Family Together
      </h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">
        Most consultations are conducted via phone or video call since we're fellow nomads!
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="font-heading text-2xl font-bold text-dark mb-6">
            Tell Us About Your Protection Needs
          </h2>
          <ContactForm />
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2">
          <div class="bg-light-gray rounded-lg p-8 sticky top-28">
            <h3 class="font-heading text-xl font-semibold text-dark mb-6">Direct Contact</h3>

            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange/10 rounded-full flex items-center justify-center shrink-0">
                  <i class="fa-solid fa-phone text-orange"></i>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Phone</p>
                  <a href={siteInfo.phoneTel} class="text-teal hover:text-orange text-sm">
                    {siteInfo.phone}
                  </a>
                  <p class="text-xs text-gray-500 mt-1">Monday–Friday, 9 AM – 6 PM EST</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange/10 rounded-full flex items-center justify-center shrink-0">
                  <i class="fa-solid fa-envelope text-orange"></i>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Email</p>
                  <a href={`mailto:${siteInfo.email}`} class="text-teal hover:text-orange text-sm">
                    {siteInfo.email}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange/10 rounded-full flex items-center justify-center shrink-0">
                  <i class="fa-solid fa-location-dot text-orange"></i>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Address</p>
                  <p class="text-sm text-gray-600">
                    Shield Your Journey LLC<br />
                    {siteInfo.address.street}<br />
                    {siteInfo.address.city}, {siteInfo.address.state} {siteInfo.address.zip}
                  </p>
                </div>
              </div>
            </div>

            <!-- Download CTA -->
            <div class="mt-8 pt-6 border-t border-gray-200">
              <p class="font-semibold text-dark text-sm mb-2">Free Resource</p>
              <a
                href="https://checklist.shieldyourjourney.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-orange hover:text-orange-dark font-semibold text-sm"
              >
                <i class="fa-solid fa-download"></i>
                Download RV Protection Checklist
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
